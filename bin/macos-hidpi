#!/bin/bash
set -euo pipefail

APP_NAME="macOS HiDPI"
TARGET_NAME=""
TARGET_VENDOR=""
TARGET_PRODUCT=""
DISPLAY_INDEX=""
OVERRIDE_ROOT="/Library/Displays/Contents/Resources/Overrides"
DEFAULT_RESOLUTIONS=(
  "2048x1280"
  "1920x1200"
  "1800x1125"
  "1680x1050"
  "1600x1000"
  "1440x900"
  "1280x800"
)
RESOLUTIONS=("${DEFAULT_RESOLUTIONS[@]}")
CUSTOM_RESOLUTIONS=0
YES=0
FROM_APP=0

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
macOS HiDPI

Usage:
  macos-hidpi list
  macos-hidpi status [--display-index N]
  macos-hidpi generate [--output DIR] [--display-index N] [--resolutions 1600x1000,2048x1280]
  macos-hidpi install [--display-index N] [--resolutions 1600x1000,2048x1280] [--yes]
  macos-hidpi uninstall [--display-index N] [--yes]

When no target is provided, the tool asks you to choose a display.
Default HiDPI modes are inferred from the selected display's native aspect ratio.

Advanced target options:
  --display-index N   Use the numbered display shown by the list command
  --target NAME       Display product name, e.g. CFORCE
  --vendor HEX|DEC    Override VendorID, requires --product
  --product HEX|DEC   Override ProductID, requires --vendor
EOF
}

to_dec() {
  local value="$1"
  if [[ "$value" =~ ^0[xX][0-9a-fA-F]+$ ]]; then
    printf "%d" "$value"
  else
    printf "%d" "$value"
  fi
}

to_hex() {
  local value="$1"
  printf "%x" "$value"
}

split_resolutions() {
  local input="$1"
  local old_ifs="$IFS"
  IFS=", "
  # shellcheck disable=SC2206
  RESOLUTIONS=($input)
  IFS="$old_ifs"
  CUSTOM_RESOLUTIONS=1
  ((${#RESOLUTIONS[@]} > 0)) || die "No resolutions provided."
}

validate_resolution() {
  local res="$1"
  [[ "$res" =~ ^[0-9]+x[0-9]+$ ]] || die "Invalid resolution: $res"
  local width="${res%x*}"
  local height="${res#*x}"
  ((width > 0 && height > 0)) || die "Invalid resolution: $res"
}

list_displays() {
  /usr/sbin/ioreg -lw0 | /usr/bin/perl -ne '
    next unless /"DisplayAttributes"\s*=/;
    my $line = $_;
    my ($name) = $line =~ /"ProductName"="([^"]+)"/;
    my ($vendor) = $line =~ /"LegacyManufacturerID"=(\d+)/;
    my ($product) = $line =~ /"ProductID"=(\d+)/;
    my ($width) = $line =~ /"NativeFormatHorizontalPixels"=(\d+)/;
    my ($height) = $line =~ /"NativeFormatVerticalPixels"=(\d+)/;
    next unless defined $vendor && defined $product;
    $name = "Unknown" unless defined $name;
    $width = "" unless defined $width;
    $height = "" unless defined $height;
    printf "%s\t%d\t%d\t%x\t%x\t%s\t%s\n", $name, $vendor, $product, $vendor, $product, $width, $height;
  '
}

print_displays() {
  local found=0
  local index=0
  printf "%-5s %-20s %-10s %-10s %-12s\n" "Index" "Name" "VendorID" "ProductID" "Native"
  printf "%-5s %-20s %-10s %-10s %-12s\n" "-----" "----" "--------" "---------" "------"
  while IFS=$'\t' read -r name vendor_dec product_dec vendor_hex product_hex width height; do
    found=1
    index=$((index + 1))
    printf "%-5s %-20s 0x%-8s 0x%-8s %sx%s\n" "$index" "$name" "$vendor_hex" "$product_hex" "${width:-?}" "${height:-?}"
  done < <(list_displays)
  ((found == 1)) || die "No external display attributes found from ioreg."
}

assign_display_line() {
  local line="$1"
  IFS=$'\t' read -r DISPLAY_NAME DISPLAY_VENDOR_DEC DISPLAY_PRODUCT_DEC DISPLAY_VENDOR_HEX DISPLAY_PRODUCT_HEX DISPLAY_WIDTH DISPLAY_HEIGHT <<<"$line"
}

choose_display_interactively() {
  local lines=()
  local line
  local index=0
  local selection

  while IFS= read -r line; do
    lines+=("$line")
  done < <(list_displays)

  ((${#lines[@]} > 0)) || die "No display attributes found from ioreg."

  if [[ -n "$DISPLAY_INDEX" ]]; then
    [[ "$DISPLAY_INDEX" =~ ^[0-9]+$ ]] || die "--display-index must be a positive number."
    ((DISPLAY_INDEX >= 1 && DISPLAY_INDEX <= ${#lines[@]})) || die "--display-index is out of range. Run: $0 list"
    assign_display_line "${lines[$((DISPLAY_INDEX - 1))]}"
    return
  fi

  if ((${#lines[@]} == 1)); then
    assign_display_line "${lines[0]}"
    return
  fi

  [[ -t 0 ]] || die "Multiple displays found. Run '$0 list' and pass --display-index N, --target NAME, or --vendor/--product."

  echo "Choose the display to configure:"
  print_displays
  echo
  read -r -p "Display index [1-${#lines[@]}]: " selection
  [[ "$selection" =~ ^[0-9]+$ ]] || die "Invalid display index."
  ((selection >= 1 && selection <= ${#lines[@]})) || die "Display index out of range."
  index=$((selection - 1))
  assign_display_line "${lines[$index]}"
}

find_target_display() {
  local line
  local found=""

  if [[ -n "$TARGET_VENDOR" || -n "$TARGET_PRODUCT" ]]; then
    [[ -n "$TARGET_VENDOR" && -n "$TARGET_PRODUCT" ]] || die "--vendor and --product must be used together."
    DISPLAY_VENDOR_DEC="$(to_dec "$TARGET_VENDOR")"
    DISPLAY_PRODUCT_DEC="$(to_dec "$TARGET_PRODUCT")"
    DISPLAY_VENDOR_HEX="$(to_hex "$DISPLAY_VENDOR_DEC")"
    DISPLAY_PRODUCT_HEX="$(to_hex "$DISPLAY_PRODUCT_DEC")"
    DISPLAY_NAME="${TARGET_NAME:-Manual target}"
    DISPLAY_WIDTH=""
    DISPLAY_HEIGHT=""
    return
  fi

  if [[ -n "$DISPLAY_INDEX" && -n "$TARGET_NAME" ]]; then
    die "Use either --display-index or --target, not both."
  fi

  if [[ -z "$TARGET_NAME" ]]; then
    choose_display_interactively
    return
  fi

  while IFS=$'\t' read -r name vendor_dec product_dec vendor_hex product_hex width height; do
    if [[ "$name" == "$TARGET_NAME" ]]; then
      found="$name"$'\t'"$vendor_dec"$'\t'"$product_dec"$'\t'"$vendor_hex"$'\t'"$product_hex"$'\t'"$width"$'\t'"$height"
      break
    fi
  done < <(list_displays)

  [[ -n "$found" ]] || die "Could not find display named '$TARGET_NAME'. Run: $0 list"
  assign_display_line "$found"
}

near_aspect() {
  local width="$1"
  local height="$2"
  local target_w="$3"
  local target_h="$4"
  local lhs=$((width * target_h))
  local rhs=$((height * target_w))
  local diff=$((lhs > rhs ? lhs - rhs : rhs - lhs))
  local tolerance=$((rhs / 50))
  ((diff <= tolerance))
}

round_even() {
  local value="$1"
  printf "%d" "$((((value + 1) / 2) * 2))"
}

dedupe_resolutions() {
  local deduped_text=""
  local res

  for res in "${RESOLUTIONS[@]}"; do
    validate_resolution "$res"
    if [[ "$deduped_text" != *$'\n'"$res"$'\n'* ]]; then
      deduped_text+="$res"$'\n'
    fi
  done

  RESOLUTIONS=()
  while IFS= read -r res; do
    [[ -n "$res" ]] && RESOLUTIONS+=("$res")
  done <<<"$deduped_text"
}

apply_default_resolutions_for_display() {
  ((CUSTOM_RESOLUTIONS == 0)) || {
    dedupe_resolutions
    return
  }

  if [[ -z "${DISPLAY_WIDTH:-}" || -z "${DISPLAY_HEIGHT:-}" ]]; then
    RESOLUTIONS=("${DEFAULT_RESOLUTIONS[@]}")
    return
  fi

  if near_aspect "$DISPLAY_WIDTH" "$DISPLAY_HEIGHT" 16 10; then
    RESOLUTIONS=("2048x1280" "1920x1200" "1800x1125" "1680x1050" "1600x1000" "1440x900" "1280x800")
  elif near_aspect "$DISPLAY_WIDTH" "$DISPLAY_HEIGHT" 16 9; then
    RESOLUTIONS=("2560x1440" "2304x1296" "2048x1152" "1920x1080" "1680x945" "1600x900" "1440x810" "1280x720")
  elif near_aspect "$DISPLAY_WIDTH" "$DISPLAY_HEIGHT" 3 2; then
    RESOLUTIONS=("2250x1500" "1920x1280" "1680x1120" "1500x1000" "1440x960" "1280x854")
  elif near_aspect "$DISPLAY_WIDTH" "$DISPLAY_HEIGHT" 4 3; then
    RESOLUTIONS=("1600x1200" "1440x1080" "1280x960" "1152x864" "1024x768")
  elif near_aspect "$DISPLAY_WIDTH" "$DISPLAY_HEIGHT" 21 9; then
    RESOLUTIONS=("3440x1440" "2752x1152" "2580x1080" "2365x990" "1935x810" "1720x720")
  else
    local percentages=(80 75 67 60 50)
    local pct
    RESOLUTIONS=()
    for pct in "${percentages[@]}"; do
      RESOLUTIONS+=("$(round_even "$((DISPLAY_WIDTH * pct / 100))")x$(round_even "$((DISPLAY_HEIGHT * pct / 100))")")
    done
  fi

  dedupe_resolutions
}

encoded_mode_prefix() {
  local width="$1"
  local height="$2"
  /usr/bin/printf "%08x %08x" "$((width * 2))" "$((height * 2))" | /usr/bin/xxd -r -p | /usr/bin/base64 | /usr/bin/cut -c 1-11
}

resolution_data_values() {
  local res="$1"
  validate_resolution "$res"

  local width="${res%x*}"
  local height="${res#*x}"
  local prefix
  prefix="$(encoded_mode_prefix "$width" "$height")"

  # These suffixes mirror the custom-resolution mode variants used by one-key-hidpi.
  printf "%sAAAAB\n" "$prefix"
  printf "%sAAAABACAAAA==\n" "$prefix"
}

existing_data_values() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  /usr/bin/plutil -convert xml1 -o - "$file" |
    /usr/bin/sed -n 's/^[[:space:]]*<data>\(.*\)<\/data>.*/\1/p'
}

write_override_plist() {
  local file="$1"
  local existing_file="${2:-}"
  : >"$file"
  cat >>"$file" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>DisplayProductID</key>
            <integer>${DISPLAY_PRODUCT_DEC}</integer>
        <key>DisplayVendorID</key>
            <integer>${DISPLAY_VENDOR_DEC}</integer>
        <key>scale-resolutions</key>
            <array>
EOF

  local res
  {
    [[ -n "$existing_file" ]] && existing_data_values "$existing_file"
    for res in "${RESOLUTIONS[@]}"; do
      resolution_data_values "$res"
    done
  } | /usr/bin/awk 'NF && !seen[$0]++ { printf "                <data>%s</data>\n", $0 }' >>"$file"

  cat >>"$file" <<'EOF'
            </array>
        <key>target-default-ppmm</key>
            <real>10.0699301</real>
    </dict>
</plist>
EOF
}

shell_quote() {
  printf "'%s'" "$(printf "%s" "$1" | /usr/bin/sed "s/'/'\\\\''/g")"
}

run_as_admin() {
  local self="$1"
  shift
  local cmd
  cmd="$(shell_quote "$self")"
  local arg
  for arg in "$@"; do
    cmd="$cmd $(shell_quote "$arg")"
  done
  local escaped="${cmd//\\/\\\\}"
  escaped="${escaped//\"/\\\"}"
  /usr/bin/osascript -e "do shell script \"$escaped\" with administrator privileges"
}

ensure_root_for_write() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    if [[ -t 0 ]]; then
      exec /usr/bin/sudo "$0" "$@"
    else
      run_as_admin "$0" "$@"
      exit 0
    fi
  fi
}

confirm() {
  local prompt="$1"
  if ((YES == 1)); then
    return
  fi
  read -r -p "$prompt [y/N] " answer
  [[ "$answer" == "y" || "$answer" == "Y" ]] || die "Cancelled."
}

target_file_path() {
  printf "%s/DisplayVendorID-%s/DisplayProductID-%s" "$OVERRIDE_ROOT" "$DISPLAY_VENDOR_HEX" "$DISPLAY_PRODUCT_HEX"
}

generate_local() {
  local output_dir="$1"
  find_target_display
  apply_default_resolutions_for_display
  local vendor_dir="$output_dir/DisplayVendorID-$DISPLAY_VENDOR_HEX"
  local file="$vendor_dir/DisplayProductID-$DISPLAY_PRODUCT_HEX"
  /bin/mkdir -p "$vendor_dir"
  write_override_plist "$file"
  /usr/bin/plutil -lint "$file" >/dev/null
  echo "$file"
}

install_override() {
  ensure_root_for_write "$@"
  find_target_display
  apply_default_resolutions_for_display

  local tmp_dir
  tmp_dir="$(/usr/bin/mktemp -d "${TMPDIR:-/tmp}/cforce-hidpi.XXXXXX")"
  trap '/bin/rm -rf "$tmp_dir"' EXIT

  local vendor_dir="$tmp_dir/DisplayVendorID-$DISPLAY_VENDOR_HEX"
  local staged_file="$vendor_dir/DisplayProductID-$DISPLAY_PRODUCT_HEX"
  local target_file
  target_file="$(target_file_path)"
  /bin/mkdir -p "$vendor_dir"
  write_override_plist "$staged_file" "$target_file"
  /usr/bin/plutil -lint "$staged_file" >/dev/null

  local target_dir="$OVERRIDE_ROOT/DisplayVendorID-$DISPLAY_VENDOR_HEX"

  confirm "Install HiDPI override for $DISPLAY_NAME ($DISPLAY_VENDOR_HEX:$DISPLAY_PRODUCT_HEX)?"
  /bin/mkdir -p "$target_dir"

  if [[ -f "$target_file" ]]; then
    /bin/cp -p "$target_file" "$target_file.backup-$(/bin/date +%Y%m%d-%H%M%S)"
  fi

  /bin/cp "$staged_file" "$target_file"
  /usr/sbin/chown root:wheel "$target_file"
  /bin/chmod 0644 "$target_file"
  /usr/bin/defaults write /Library/Preferences/com.apple.windowserver DisplayResolutionEnabled -bool YES

  echo "Installed $APP_NAME override:"
  echo "  Display: $DISPLAY_NAME (${DISPLAY_WIDTH:-?}x${DISPLAY_HEIGHT:-?})"
  echo "  File: $target_file"
  echo "  Modes: ${RESOLUTIONS[*]}"
  echo "Restart macOS, then open System Settings > Displays and choose a scaled HiDPI mode."
}

uninstall_override() {
  ensure_root_for_write "$@"
  find_target_display

  local target_file
  target_file="$(target_file_path)"
  confirm "Remove HiDPI override for $DISPLAY_NAME ($DISPLAY_VENDOR_HEX:$DISPLAY_PRODUCT_HEX)?"
  if [[ -f "$target_file" ]]; then
    /bin/rm -f "$target_file"
    /bin/rmdir "$OVERRIDE_ROOT/DisplayVendorID-$DISPLAY_VENDOR_HEX" 2>/dev/null || true
    echo "Removed: $target_file"
  else
    echo "No override file found: $target_file"
  fi
  echo "Restart macOS for the change to fully apply."
}

status() {
  find_target_display
  local target_file
  target_file="$(target_file_path)"
  echo "Display: $DISPLAY_NAME"
  echo "Vendor/Product: 0x$DISPLAY_VENDOR_HEX / 0x$DISPLAY_PRODUCT_HEX"
  echo "Native: ${DISPLAY_WIDTH:-?}x${DISPLAY_HEIGHT:-?}"
  if [[ -f "$target_file" ]]; then
    echo "Override: installed at $target_file"
  else
    echo "Override: not installed"
  fi
}

ACTION="${1:-}"
[[ -n "$ACTION" ]] || {
  usage
  exit 0
}
shift || true

OUTPUT_DIR="./generated"
ORIGINAL_ARGS=("$ACTION" "$@")

while (($#)); do
  case "$1" in
    --target)
      TARGET_NAME="${2:-}"
      shift 2
      ;;
    --display-index)
      DISPLAY_INDEX="${2:-}"
      shift 2
      ;;
    --vendor)
      TARGET_VENDOR="${2:-}"
      shift 2
      ;;
    --product)
      TARGET_PRODUCT="${2:-}"
      shift 2
      ;;
    --resolutions)
      split_resolutions "${2:-}"
      shift 2
      ;;
    --output)
      OUTPUT_DIR="${2:-}"
      shift 2
      ;;
    --yes|-y)
      YES=1
      shift
      ;;
    --from-app)
      FROM_APP=1
      YES=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "Unknown option: $1"
      ;;
  esac
done

case "$ACTION" in
  list)
    print_displays
    ;;
  status)
    status
    ;;
  generate)
    generated_file="$(generate_local "$OUTPUT_DIR")"
    echo "Generated: $generated_file"
    ;;
  install)
    install_override "${ORIGINAL_ARGS[@]}"
    ;;
  uninstall)
    uninstall_override "${ORIGINAL_ARGS[@]}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
