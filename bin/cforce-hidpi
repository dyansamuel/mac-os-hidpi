#!/bin/bash
set -euo pipefail

APP_NAME="CFORCE HiDPI"
TARGET_NAME="CFORCE"
TARGET_VENDOR=""
TARGET_PRODUCT=""
OVERRIDE_ROOT="/Library/Displays/Contents/Resources/Overrides"
DEFAULT_RESOLUTIONS=(
  "2048x1280"
  "1920x1200"
  "1800x1125"
  "1680x1050"
  "1600x1000"
  "1440x900"
  "1280x800"
)
RESOLUTIONS=("${DEFAULT_RESOLUTIONS[@]}")
YES=0
FROM_APP=0

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
CFORCE HiDPI

Usage:
  cforce-hidpi list
  cforce-hidpi status
  cforce-hidpi generate [--output DIR] [--resolutions 1600x1000,2048x1280]
  cforce-hidpi install [--resolutions 1600x1000,2048x1280] [--yes]
  cforce-hidpi uninstall [--yes]

Defaults target the CFORCE display and install these 16:10 HiDPI modes:
  2048x1280, 1920x1200, 1800x1125, 1680x1050, 1600x1000, 1440x900, 1280x800

Advanced target options:
  --target NAME       Display product name, default CFORCE
  --vendor HEX|DEC    Override VendorID, e.g. 0x4a8b
  --product HEX|DEC   Override ProductID, e.g. 0xcf
EOF
}

to_dec() {
  local value="$1"
  if [[ "$value" =~ ^0[xX][0-9a-fA-F]+$ ]]; then
    printf "%d" "$value"
  else
    printf "%d" "$value"
  fi
}

to_hex() {
  local value="$1"
  printf "%x" "$value"
}

split_resolutions() {
  local input="$1"
  local old_ifs="$IFS"
  IFS=", "
  # shellcheck disable=SC2206
  RESOLUTIONS=($input)
  IFS="$old_ifs"
  ((${#RESOLUTIONS[@]} > 0)) || die "No resolutions provided."
}

validate_resolution() {
  local res="$1"
  [[ "$res" =~ ^[0-9]+x[0-9]+$ ]] || die "Invalid resolution: $res"
  local width="${res%x*}"
  local height="${res#*x}"
  ((width > 0 && height > 0)) || die "Invalid resolution: $res"
}

list_displays() {
  /usr/sbin/ioreg -lw0 | /usr/bin/perl -ne '
    next unless /"DisplayAttributes"\s*=/;
    my $line = $_;
    my ($name) = $line =~ /"ProductName"="([^"]+)"/;
    my ($vendor) = $line =~ /"LegacyManufacturerID"=(\d+)/;
    my ($product) = $line =~ /"ProductID"=(\d+)/;
    my ($width) = $line =~ /"NativeFormatHorizontalPixels"=(\d+)/;
    my ($height) = $line =~ /"NativeFormatVerticalPixels"=(\d+)/;
    next unless defined $vendor && defined $product;
    $name = "Unknown" unless defined $name;
    $width = "" unless defined $width;
    $height = "" unless defined $height;
    printf "%s\t%d\t%d\t%x\t%x\t%s\t%s\n", $name, $vendor, $product, $vendor, $product, $width, $height;
  '
}

print_displays() {
  local found=0
  printf "%-20s %-10s %-10s %-12s\n" "Name" "VendorID" "ProductID" "Native"
  printf "%-20s %-10s %-10s %-12s\n" "----" "--------" "---------" "------"
  while IFS=$'\t' read -r name vendor_dec product_dec vendor_hex product_hex width height; do
    found=1
    printf "%-20s 0x%-8s 0x%-8s %sx%s\n" "$name" "$vendor_hex" "$product_hex" "${width:-?}" "${height:-?}"
  done < <(list_displays)
  ((found == 1)) || die "No external display attributes found from ioreg."
}

find_target_display() {
  local line
  local found=""

  if [[ -n "$TARGET_VENDOR" && -n "$TARGET_PRODUCT" ]]; then
    DISPLAY_VENDOR_DEC="$(to_dec "$TARGET_VENDOR")"
    DISPLAY_PRODUCT_DEC="$(to_dec "$TARGET_PRODUCT")"
    DISPLAY_VENDOR_HEX="$(to_hex "$DISPLAY_VENDOR_DEC")"
    DISPLAY_PRODUCT_HEX="$(to_hex "$DISPLAY_PRODUCT_DEC")"
    DISPLAY_NAME="$TARGET_NAME"
    DISPLAY_WIDTH=""
    DISPLAY_HEIGHT=""
    return
  fi

  while IFS=$'\t' read -r name vendor_dec product_dec vendor_hex product_hex width height; do
    if [[ "$name" == "$TARGET_NAME" ]]; then
      found="$name"$'\t'"$vendor_dec"$'\t'"$product_dec"$'\t'"$vendor_hex"$'\t'"$product_hex"$'\t'"$width"$'\t'"$height"
      break
    fi
  done < <(list_displays)

  [[ -n "$found" ]] || die "Could not find display named '$TARGET_NAME'. Run: $0 list"
  IFS=$'\t' read -r DISPLAY_NAME DISPLAY_VENDOR_DEC DISPLAY_PRODUCT_DEC DISPLAY_VENDOR_HEX DISPLAY_PRODUCT_HEX DISPLAY_WIDTH DISPLAY_HEIGHT <<<"$found"
}

encoded_mode_prefix() {
  local width="$1"
  local height="$2"
  /usr/bin/printf "%08x %08x" "$((width * 2))" "$((height * 2))" | /usr/bin/xxd -r -p | /usr/bin/base64 | /usr/bin/cut -c 1-11
}

resolution_data_values() {
  local res="$1"
  validate_resolution "$res"

  local width="${res%x*}"
  local height="${res#*x}"
  local prefix
  prefix="$(encoded_mode_prefix "$width" "$height")"

  # These suffixes mirror the custom-resolution mode variants used by one-key-hidpi.
  printf "%sAAAAB\n" "$prefix"
  printf "%sAAAABACAAAA==\n" "$prefix"
}

existing_data_values() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  /usr/bin/plutil -convert xml1 -o - "$file" |
    /usr/bin/sed -n 's/^[[:space:]]*<data>\(.*\)<\/data>.*/\1/p'
}

write_override_plist() {
  local file="$1"
  local existing_file="${2:-}"
  : >"$file"
  cat >>"$file" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>DisplayProductID</key>
            <integer>${DISPLAY_PRODUCT_DEC}</integer>
        <key>DisplayVendorID</key>
            <integer>${DISPLAY_VENDOR_DEC}</integer>
        <key>scale-resolutions</key>
            <array>
EOF

  local res
  {
    [[ -n "$existing_file" ]] && existing_data_values "$existing_file"
    for res in "${RESOLUTIONS[@]}"; do
      resolution_data_values "$res"
    done
  } | /usr/bin/awk 'NF && !seen[$0]++ { printf "                <data>%s</data>\n", $0 }' >>"$file"

  cat >>"$file" <<'EOF'
            </array>
        <key>target-default-ppmm</key>
            <real>10.0699301</real>
    </dict>
</plist>
EOF
}

shell_quote() {
  printf "'%s'" "$(printf "%s" "$1" | /usr/bin/sed "s/'/'\\\\''/g")"
}

run_as_admin() {
  local self="$1"
  shift
  local cmd
  cmd="$(shell_quote "$self")"
  local arg
  for arg in "$@"; do
    cmd="$cmd $(shell_quote "$arg")"
  done
  local escaped="${cmd//\\/\\\\}"
  escaped="${escaped//\"/\\\"}"
  /usr/bin/osascript -e "do shell script \"$escaped\" with administrator privileges"
}

ensure_root_for_write() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    if [[ -t 0 ]]; then
      exec /usr/bin/sudo "$0" "$@"
    else
      run_as_admin "$0" "$@"
      exit 0
    fi
  fi
}

confirm() {
  local prompt="$1"
  if ((YES == 1)); then
    return
  fi
  read -r -p "$prompt [y/N] " answer
  [[ "$answer" == "y" || "$answer" == "Y" ]] || die "Cancelled."
}

target_file_path() {
  printf "%s/DisplayVendorID-%s/DisplayProductID-%s" "$OVERRIDE_ROOT" "$DISPLAY_VENDOR_HEX" "$DISPLAY_PRODUCT_HEX"
}

generate_local() {
  local output_dir="$1"
  find_target_display
  local vendor_dir="$output_dir/DisplayVendorID-$DISPLAY_VENDOR_HEX"
  local file="$vendor_dir/DisplayProductID-$DISPLAY_PRODUCT_HEX"
  /bin/mkdir -p "$vendor_dir"
  write_override_plist "$file"
  /usr/bin/plutil -lint "$file" >/dev/null
  echo "$file"
}

install_override() {
  ensure_root_for_write "$@"
  find_target_display

  local tmp_dir
  tmp_dir="$(/usr/bin/mktemp -d "${TMPDIR:-/tmp}/cforce-hidpi.XXXXXX")"
  trap '/bin/rm -rf "$tmp_dir"' EXIT

  local vendor_dir="$tmp_dir/DisplayVendorID-$DISPLAY_VENDOR_HEX"
  local staged_file="$vendor_dir/DisplayProductID-$DISPLAY_PRODUCT_HEX"
  local target_file
  target_file="$(target_file_path)"
  /bin/mkdir -p "$vendor_dir"
  write_override_plist "$staged_file" "$target_file"
  /usr/bin/plutil -lint "$staged_file" >/dev/null

  local target_dir="$OVERRIDE_ROOT/DisplayVendorID-$DISPLAY_VENDOR_HEX"

  confirm "Install HiDPI override for $DISPLAY_NAME ($DISPLAY_VENDOR_HEX:$DISPLAY_PRODUCT_HEX)?"
  /bin/mkdir -p "$target_dir"

  if [[ -f "$target_file" ]]; then
    /bin/cp -p "$target_file" "$target_file.backup-$(/bin/date +%Y%m%d-%H%M%S)"
  fi

  /bin/cp "$staged_file" "$target_file"
  /usr/sbin/chown root:wheel "$target_file"
  /bin/chmod 0644 "$target_file"
  /usr/bin/defaults write /Library/Preferences/com.apple.windowserver DisplayResolutionEnabled -bool YES

  echo "Installed $APP_NAME override:"
  echo "  Display: $DISPLAY_NAME (${DISPLAY_WIDTH:-?}x${DISPLAY_HEIGHT:-?})"
  echo "  File: $target_file"
  echo "  Modes: ${RESOLUTIONS[*]}"
  echo "Restart macOS, then open System Settings > Displays and choose a scaled HiDPI mode."
}

uninstall_override() {
  ensure_root_for_write "$@"
  find_target_display

  local target_file
  target_file="$(target_file_path)"
  confirm "Remove HiDPI override for $DISPLAY_NAME ($DISPLAY_VENDOR_HEX:$DISPLAY_PRODUCT_HEX)?"
  if [[ -f "$target_file" ]]; then
    /bin/rm -f "$target_file"
    /bin/rmdir "$OVERRIDE_ROOT/DisplayVendorID-$DISPLAY_VENDOR_HEX" 2>/dev/null || true
    echo "Removed: $target_file"
  else
    echo "No override file found: $target_file"
  fi
  echo "Restart macOS for the change to fully apply."
}

status() {
  find_target_display
  local target_file
  target_file="$(target_file_path)"
  echo "Display: $DISPLAY_NAME"
  echo "Vendor/Product: 0x$DISPLAY_VENDOR_HEX / 0x$DISPLAY_PRODUCT_HEX"
  echo "Native: ${DISPLAY_WIDTH:-?}x${DISPLAY_HEIGHT:-?}"
  if [[ -f "$target_file" ]]; then
    echo "Override: installed at $target_file"
  else
    echo "Override: not installed"
  fi
}

ACTION="${1:-}"
[[ -n "$ACTION" ]] || {
  usage
  exit 0
}
shift || true

OUTPUT_DIR="./generated"
ORIGINAL_ARGS=("$ACTION" "$@")

while (($#)); do
  case "$1" in
    --target)
      TARGET_NAME="${2:-}"
      shift 2
      ;;
    --vendor)
      TARGET_VENDOR="${2:-}"
      shift 2
      ;;
    --product)
      TARGET_PRODUCT="${2:-}"
      shift 2
      ;;
    --resolutions)
      split_resolutions "${2:-}"
      shift 2
      ;;
    --output)
      OUTPUT_DIR="${2:-}"
      shift 2
      ;;
    --yes|-y)
      YES=1
      shift
      ;;
    --from-app)
      FROM_APP=1
      YES=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "Unknown option: $1"
      ;;
  esac
done

case "$ACTION" in
  list)
    print_displays
    ;;
  status)
    status
    ;;
  generate)
    generated_file="$(generate_local "$OUTPUT_DIR")"
    echo "Generated: $generated_file"
    ;;
  install)
    install_override "${ORIGINAL_ARGS[@]}"
    ;;
  uninstall)
    uninstall_override "${ORIGINAL_ARGS[@]}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
